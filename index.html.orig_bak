<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#1a6b4a">
<title>中医康复病历助手</title>
<link rel="manifest" href="manifest.json">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif;background:#f0f4f3;color:#222;font-size:15px;line-height:1.6;padding-bottom:70px;}
#splash{position:fixed;inset:0;background:#1a6b4a;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity .4s;}
#splash.hide{opacity:0;pointer-events:none;}
#splash .logo{font-size:48px;margin-bottom:12px;}
#splash h1{color:#fff;font-size:20px;font-weight:600;}
#splash .sub{color:rgba(255,255,255,.6);font-size:13px;margin-top:6px;}
#splash .err{color:#ff8a80;font-size:12px;margin-top:20px;padding:0 30px;text-align:center;display:none;}
.app-header{background:linear-gradient(135deg,#1a6b4a,#2a8b6a);color:#fff;padding:20px 16px 16px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,.15);}
.app-header h1{font-size:20px;font-weight:700;}
.app-header .sub{font-size:12px;opacity:.8;margin-top:2px;}
.section-title{padding:16px 16px 8px;font-size:15px;font-weight:700;color:#333;}
.disease-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:8px 16px;}
.disease-card{background:#fff;border-radius:12px;padding:14px 12px;box-shadow:0 1px 4px rgba(0,0,0,.08);cursor:pointer;transition:.2s;}
.disease-card:active{transform:scale(.97);background:#f5faf8;}
.disease-card .icon{font-size:28px;margin-bottom:4px;}
.disease-card .name{font-size:14px;font-weight:600;color:#222;}
.disease-card .desc{font-size:11px;color:#999;margin-top:2px;}
.template-list{padding:8px 16px;}
.t-item{background:#fff;border-radius:10px;padding:14px 16px;margin-bottom:8px;box-shadow:0 1px 3px rgba(0,0,0,.06);cursor:pointer;display:flex;align-items:center;gap:12px;}
.t-item:active{background:#f5faf8;}
.t-item .icon{font-size:24px;flex-shrink:0;}
.t-item .info{flex:1;}
.t-item .name{font-size:14px;font-weight:600;}
.t-item .desc{font-size:12px;color:#888;margin-top:1px;}
.t-item .arrow{color:#bbb;font-size:18px;}
.editor-page{display:none;}
.editor-page.active{display:block;}
.editor-header{background:#fff;position:sticky;top:0;z-index:100;padding:12px 16px;border-bottom:1px solid #eee;display:flex;align-items:center;gap:12px;}
.editor-header .back{font-size:24px;cursor:pointer;padding:4px;}
.editor-header .title{font-size:16px;font-weight:600;flex:1;}
.editor-body{padding:12px 16px;max-width:640px;margin:0 auto;}
.form-group{margin-bottom:14px;}
.form-group label{display:block;font-size:13px;font-weight:600;color:#444;margin-bottom:4px;}
.form-group input,.form-group textarea,.form-group select{width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:8px;font-size:14px;font-family:inherit;background:#fff;}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{outline:none;border-color:#2a8b6a;box-shadow:0 0 0 3px rgba(42,139,106,.15);}
.form-group textarea{min-height:70px;resize:vertical;}
.form-group textarea.tall{min-height:140px;}
.form-group .help-text{font-size:11px;color:#999;margin-top:2px;}
.btn-row{display:flex;gap:10px;margin:16px 0 24px;flex-wrap:wrap;}
.btn{padding:10px 20px;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;flex:1;min-width:80px;text-align:center;}
.btn:active{transform:scale(.97);}
.btn-primary{background:#1a6b4a;color:#fff;}
.btn-success{background:#43a047;color:#fff;}
.btn-outline{background:transparent;border:1.5px solid #1a6b4a;color:#1a6b4a;}
.btn-danger{background:#e53935;color:#fff;}
.btn-gray{background:#eee;color:#555;}
#outputBox{background:#fff;border-radius:10px;padding:16px;margin:12px 0;white-space:pre-wrap;font-size:13px;line-height:1.8;border:1px solid #e0e0e0;display:none;max-height:500px;overflow-y:auto;}
#outputBox.show{display:block;}
#insuranceBox{background:#fff8e1;border:1px solid #ffe082;border-radius:10px;padding:12px 16px;margin:12px 0;display:none;}
#insuranceBox.show{display:block;}
#insuranceBox .title{font-weight:700;color:#f57f17;font-size:13px;margin-bottom:6px;}
#insuranceBox li{font-size:12px;color:#555;padding:3px 0 3px 16px;position:relative;list-style:none;}
#insuranceBox li::before{content:"⚠️";position:absolute;left:0;font-size:10px;}
.saved-item{background:#fff;border-radius:10px;padding:12px 16px;margin-bottom:8px;box-shadow:0 1px 3px rgba(0,0,0,.06);border-left:3px solid #1a6b4a;}
.saved-item .s-title{font-weight:600;font-size:14px;}
.saved-item .s-meta{font-size:11px;color:#999;margin-top:2px;}
.saved-item .s-actions{display:flex;gap:6px;margin-top:8px;}
.saved-item .s-actions button{padding:6px 10px;border:none;border-radius:6px;font-size:11px;cursor:pointer;}
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid #eee;display:flex;padding:6px 0 calc(6px + env(safe-area-inset-bottom));z-index:200;}
.bottom-nav .item{flex:1;text-align:center;padding:6px 0;cursor:pointer;}
.bottom-nav .item .icon{font-size:22px;}
.bottom-nav .item .label{font-size:10px;color:#888;margin-top:1px;}
.bottom-nav .item.active .label{color:#1a6b4a;font-weight:600;}
.page{display:none;}
.page.active{display:block;}
.search-box{margin:8px 16px;position:relative;}
.search-box input{width:100%;padding:10px 14px 10px 36px;border:1px solid #ddd;border-radius:10px;font-size:14px;background:#fff;}
.search-box .search-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:16px;color:#999;}
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.85);color:#fff;padding:8px 20px;border-radius:20px;font-size:13px;z-index:999;opacity:0;transition:.3s;pointer-events:none;text-align:center;max-width:80%;}
.toast.show{opacity:1;}
#copyToast{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,.8);color:#fff;padding:20px 30px;border-radius:12px;font-size:16px;z-index:9999;opacity:0;transition:.3s;pointer-events:none;text-align:center;}
#copyToast.show{opacity:1;}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.anim-in{animation:fadeIn .25s ease-out;}
@media(min-width:600px){.disease-grid{grid-template-columns:1fr 1fr 1fr;}}
</style>
</head>
<body>

<div id="splash">
  <div class="logo">🏥</div>
  <h1>中医康复病历助手</h1>
  <div class="sub">加载中...</div>
  <div class="err" id="splashErr"></div>
</div>

<div id="copyToast">📋 已复制到剪贴板</div>
<div id="toast" class="toast"></div>

<div class="page active" id="pageHome">
  <div class="app-header"><h1>🌿 中医康复病历助手</h1><div class="sub">内科病房 · 入院→出院 · 医保合规</div></div>
  <div class="search-box"><span class="search-icon">🔍</span><input type="text" id="searchInput" placeholder="搜索病种..."></div>
  <div class="section-title">📂 选择病种</div>
  <div id="diseaseGrid" class="disease-grid"></div>
</div>

<div class="page" id="pageTemplates">
  <div class="app-header" style="padding:12px 16px;display:flex;align-items:center;gap:12px;">
    <span style="font-size:24px;cursor:pointer;" id="backHomeBtn">‹</span>
    <div><h1 style="font-size:17px;" id="tplDiseaseName"></h1><div class="sub" style="font-size:11px;">选择文书类型</div></div>
  </div>
  <div id="tplList" class="template-list"></div>
</div>

<div class="page editor-page" id="pageEditor">
  <div class="editor-header">
    <span class="back" id="backTplBtn">‹</span>
    <span class="title" id="editorTitle">编辑器</span>
    <span style="font-size:18px;cursor:pointer;" id="insBtn" title="医保合规提示">🛡️</span>
  </div>
  <div id="insuranceBox"></div>
  <div id="editorBody" class="editor-body"></div>
</div>

<div class="page" id="pageSaved">
  <div class="app-header" style="padding:12px 16px;display:flex;align-items:center;gap:12px;">
    <span style="font-size:24px;cursor:pointer;" id="backHomeBtn2">‹</span>
    <div><h1 style="font-size:17px;">📁 已保存记录</h1><div class="sub" id="savedCount">共 0 条</div></div>
  </div>
  <div style="padding:12px 16px;" id="savedList"></div>
</div>

<nav class="bottom-nav">
  <div class="item active" id="navHome"><div class="icon">🏠</div><div class="label">首页</div></div>
  <div class="item" id="navSaved"><div class="icon">📁</div><div class="label">已保存</div></div>
</nav>

<script>
(function(){
'use strict';

// ===== SAFE UTILITIES =====
function $(id){return document.getElementById(id);}
function qs(s,ctx){return (ctx||document).querySelector(s);}
function qsa(s,ctx){return (ctx||document).querySelectorAll(s);}
function showToast(msg){var t=$('toast');t.textContent=msg;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2000);}
function showCopyToast(){var t=$('copyToast');t.classList.add('show');setTimeout(function(){t.classList.remove('show');},1500);}
function copyText(txt){
  if(navigator.clipboard&&navigator.clipboard.writeText){
    navigator.clipboard.writeText(txt).then(showCopyToast).catch(function(){showToast('复制失败，请手动复制');});
  }else{
    var ta=document.createElement('textarea');
    ta.value=txt;ta.style.position='fixed';ta.style.left='-9999px';ta.style.top='0';
    document.body.appendChild(ta);ta.select();
    try{document.execCommand('copy');showCopyToast();}catch(e){showToast('复制失败');}
    document.body.removeChild(ta);
  }
}
function safeGet(obj,key,def){return (obj&&obj[key]!==undefined&&obj[key]!==null)?obj[key]:def;}
function safeStr(v){return (v===undefined||v===null)?'______':String(v);}

// ===== DISEASE DATA =====
var DISEASES=[
  {id:'stroke',name:'中风病（脑梗死恢复期）',icon:'🧠',short:'中风',tcm:'中风病',west:'脑梗死恢复期',syndrome:'气虚血瘀证',
   exam:'神志清楚，言语欠清晰，右侧鼻唇沟变浅，伸舌右偏，右上肢肌力III级，下肢肌力IV级，肌张力增高，右侧巴氏征(+)',
   plan:'1.中医中药：益气活血通络，方用补阳还五汤加减\n2.针灸治疗：取穴百会、四神聪、风池、肩髃、曲池、手三里、合谷、环跳、阳陵泉、足三里、太冲\n3.康复训练：偏瘫肢体综合训练、平衡训练、言语训练\n4.西医治疗：控制血压、抗血小板、调脂稳斑',
   diff:'1.与脑出血鉴别：脑出血起病更急，常有意识障碍，CT可见高密度灶\n2.与颅内占位鉴别：颅内肿瘤起病缓慢，进行性加重，头颅MRI可明确\n3.与TIA鉴别：TIA症状持续时间短（<24小时），可完全恢复，无梗死灶',
   ins:['脑梗死恢复期康复治疗医保支付有明确标准','醒脑静注射液限二级以上医疗机构中风昏迷患者使用','康复治疗项目（运动疗法、作业疗法、言语治疗）为医保甲类','住院康复一般不超过90天']},
  {id:'vertigo',name:'眩晕（颈椎病）',icon:'🌀',short:'眩晕',tcm:'眩晕',west:'颈椎病',syndrome:'痰湿中阻证',
   exam:'颈椎生理曲度变直，C3-7棘突及椎旁压痛(+)，旋颈试验(+)，双上肢感觉无异常',
   plan:'1.中医中药：化痰祛湿通络，方用半夏白术天麻汤加减\n2.针灸治疗：取穴风池、百会、颈夹脊、肩井、外关、合谷\n3.推拿治疗：颈项部松解手法\n4.牵引治疗：颈椎牵引\n5.物理治疗：超短波、中频电疗',
   diff:'1.与后循环缺血鉴别：后循环缺血多伴复视、构音障碍、共济失调等脑干小脑体征\n2.与耳石症鉴别：耳石症眩晕与头位改变密切相关，持续时间短（数秒至数分钟），无颈椎症状\n3.与梅尼埃病鉴别：梅尼埃病伴耳鸣、听力下降，眩晕发作有规律性',
   ins:['颈椎牵引治疗为医保甲类，需记录牵引重量/时间','超短波治疗、中频电疗为医保甲类','同一部位物理治疗每日不超过2项','脊椎病保守治疗住院一般14-21天']},
  {id:'lumbar',name:'腰痛（腰椎间盘突出症）',icon:'🔙',short:'腰痛',tcm:'腰痛',west:'腰椎间盘突出症',syndrome:'气滞血瘀证',
   exam:'腰椎生理曲度变直，L4-S1棘突间及椎旁压痛(+)，直腿抬高试验左60°(+)右70°(-)，双下肢肌力V级',
   plan:'1.中医中药：活血化瘀通络止痛，方用身痛逐瘀汤加减\n2.针灸治疗：取穴肾俞、大肠俞、腰阳关、环跳、委中、承山\n3.推拿治疗：腰部推拿整复\n4.牵引治疗：腰椎牵引\n5.物理治疗：中频电疗、蜡疗',
   diff:'1.与腰椎管狭窄症鉴别：腰椎管狭窄症以间歇性跛行为特征，后伸时加重，前屈时减轻\n2.与肾结石鉴别：肾结石腰痛剧烈，呈绞痛，放射至会阴部，伴血尿\n3.与骨质疏松性骨折鉴别：多见于老年人，轻微外伤后突发剧痛',
   ins:['腰椎间盘突出保守治疗住院14-21天','推拿治疗需记录手法类型及部位','牵引治疗需有影像学依据','活血化瘀类中成药需辨证有瘀血指征']},
  {id:'facial',name:'面瘫（面神经炎）',icon:'😐',short:'面瘫',tcm:'面瘫',west:'面神经炎',syndrome:'风痰阻络证',
   exam:'左侧额纹消失，左眼闭合不全，左侧鼻唇沟变浅，口角向右歪斜，左耳后乳突区压痛(+)',
   plan:'1.中医中药：祛风化痰通络，方用牵正散加减\n2.针灸治疗：取穴阳白、四白、颊车、地仓、翳风、合谷、太冲\n3.面部功能训练\n4.物理治疗：红外线照射、超短波',
   diff:'1.与中枢性面瘫鉴别：中枢性面瘫仅眼裂以下面部表情肌瘫痪，额纹存在，伴偏瘫症状\n2.与Ramsay Hunt综合征鉴别：耳部疱疹、耳痛、听力下降\n3.与格林-巴利综合征鉴别：双侧周围性面瘫，伴四肢对称性弛缓性瘫痪',
   ins:['面神经炎针灸治疗为医保甲类','急性期使用糖皮质激素需有明确指征','红外线照射、超短波为医保甲类','一般住院14天左右评估']},
  {id:'shoulder',name:'肩凝症（肩周炎）',icon:'💪',short:'肩凝',tcm:'肩凝症',west:'肩关节周围炎',syndrome:'寒湿痹阻证',
   exam:'右肩关节活动受限，前屈60°，外展50°，后伸20°，肩峰下压痛(+)，Neer征(+)',
   plan:'1.中医中药：散寒除湿通络，方用蠲痹汤加减\n2.针灸治疗：取穴肩髃、肩髎、肩贞、阿是穴、曲池、外关\n3.推拿治疗：肩关节松解手法\n4.康复训练：关节松动术、爬墙训练\n5.物理治疗：中频电疗、蜡疗',
   diff:'1.与肩袖损伤鉴别：肩袖损伤主动活动受限而被动活动基本正常，肩峰下撞击征(+)\n2.与肱二头肌长头腱鞘炎鉴别：肱二头肌长头腱处压痛明显\n3.与颈椎病肩部放射痛鉴别：颈椎病伴颈部症状及上肢放射痛',
   ins:['关节松动术为医保甲类','物理治疗项目同一部位每日不超过2项','中医小针刀治疗限高级职称医师操作','封闭注射需注明药物名称及剂量']},
  {id:'arthralgia',name:'骨痹（骨关节炎）',icon:'🦴',short:'骨痹',tcm:'骨痹',west:'膝关节骨性关节炎',syndrome:'肝肾亏虚证',
   exam:'双膝关节轻度肿胀，屈伸活动受限（ROM:主动屈曲100°），髌骨研磨试验(+)，关节无红肿发热',
   plan:'1.中医中药：补益肝肾、舒筋活络，方用独活寄生汤加减\n2.针灸治疗：取穴膝眼、梁丘、血海、足三里、阳陵泉\n3.物理治疗：超短波、中频电疗\n4.康复训练：股四头肌肌力训练、关节活动度训练',
   diff:'1.与类风湿性关节炎鉴别：对称性小关节受累，晨僵>1小时，RF/CCP抗体阳性\n2.与痛风性关节炎鉴别：急性发作关节红肿热痛，血尿酸升高\n3.与半月板损伤鉴别：有外伤史，关节交锁、弹响',
   ins:['玻璃酸钠注射限膝骨关节炎（K-L分级II-III级）','非甾体抗炎药需评估消化道风险','中药薰洗、热敷需辨证选方','康复评定需含关节活动度、肌力指标']},
  {id:'flaccidity',name:'痿证（脊髓损伤恢复期）',icon:'🦽',short:'痿证',tcm:'痿证',west:'脊髓损伤恢复期',syndrome:'脾胃虚弱证',
   exam:'双下肢肌力II-III级，肌张力低，T10平面以下感觉减退，膝腱反射(+)',
   plan:'1.中医中药：补益脾胃、益气通络，方用补中益气汤合四物汤加减\n2.针灸治疗：取穴脾俞、胃俞、足三里、三阴交、阳陵泉\n3.康复训练：肌力训练、坐位平衡、转移训练\n4.物理治疗：神经肌肉电刺激、中频电疗\n5.并发症防治：防压疮、防泌尿系感染',
   diff:'1.与格林-巴利综合征鉴别：GBS多为对称性弛缓性瘫痪，感觉障碍呈手套袜套样分布\n2.与运动神经元病鉴别：MND肌萎缩、肌束震颤，无感觉障碍\n3.与多发性硬化鉴别：MS反复发作、缓解交替，MRI脑室周围多发脱髓鞘病灶',
   ins:['脊髓损伤康复为医保重点保障项目','神经节苷脂等神经营养药限严重脑/脊髓损伤','康复治疗需有明确康复目标及阶段性评估','长期住院需定期评估康复效果']},
  {id:'poststroke',name:'中风后遗症（恢复期）',icon:'🏃',short:'中风后遗',tcm:'中风病',west:'脑梗死后遗症',syndrome:'气虚血瘀证',
   exam:'神清，言语欠流利，左上肢肌力III级，左下肢IV级，肌张力增高，可拄拐短距离行走',
   plan:'1.中医中药：益气活血通络，方用补阳还五汤加减\n2.针灸治疗：取穴百会、四神聪、肩髃、曲池、手三里、合谷、环跳、阳陵泉、足三里\n3.康复训练：偏瘫肢体综合训练、ADL训练、言语训练\n4.物理治疗：中频电疗、生物反馈',
   diff:'1.与血管性痴呆鉴别：血管性痴呆进行性认知功能下降，Hachinski缺血评分>7分\n2.与Alzheimer病鉴别：AD隐匿起病，进行性记忆障碍为主\n3.与正常颅压脑积水鉴别：NPH临床三联征：步态异常、认知障碍、尿失禁',
   ins:['中风后遗症康复与急性期治疗医保支付标准不同','言语/吞咽/作业治疗需有专项评定记录','康复辅助器具需符合医保目录','定期评估ADL改善情况']}
];

var TEMPLATES=[
  {id:'admission',name:'入院记录',icon:'📋',desc:'入院记录（含中医四诊、辨证分析）'},
  {id:'first_course',name:'首次病程记录',icon:'📝',desc:'病例特点、拟诊讨论、鉴别诊断、诊疗计划'},
  {id:'daily_course',name:'日常病程记录',icon:'📄',desc:'逐日病程、病情演变、持续康复'},
  {id:'attending_round',name:'主治医师查房记录',icon:'👨‍⚕️',desc:'主治医师查房（一周内完成）'},
  {id:'chief_round',name:'主任医师查房记录',icon:'👴',desc:'主任/副主任医师查房（两周内完成）'},
  {id:'discharge',name:'出院记录',icon:'📤',desc:'出院记录、康复指导、复诊计划'}
];

// ===== STATE =====
var curDisease=null;
var curTemplate=null;
var curForm={};
var saved=[];

try{
  var d=localStorage.getItem('zky_saved');
  if(d) saved=JSON.parse(d);
  if(!Array.isArray(saved)) saved=[];
}catch(e){saved=[];}

// ===== NAVIGATION =====
function showPage(id){
  qsa('.page.active').forEach(function(p){p.classList.remove('active');});
  var el=$(id);
  if(el) el.classList.add('active');
  qsa('.bottom-nav .item.active').forEach(function(n){n.classList.remove('active');});
  if(id==='pageHome') $('navHome').classList.add('active');
  if(id==='pageSaved') $('navSaved').classList.add('active');
}

// ===== DISEASE LIST =====
function renderDiseases(filter){
  filter=filter||'';
  var grid=$('diseaseGrid');
  var html='';
  DISEASES.forEach(function(d){
    if(filter && d.name.indexOf(filter)===-1 && d.short.indexOf(filter)===-1) return;
    html+='<div class="disease-card" data-id="'+d.id+'">'+
      '<div class="icon">'+d.icon+'</div>'+
      '<div class="name">'+d.name+'</div>'+
      '<div class="desc">'+TEMPLATES.length+'种文书 · 含鉴别诊断</div>'+
    '</div>';
  });
  grid.innerHTML=html||'<div style="text-align:center;padding:30px;color:#999;">未找到匹配病种</div>';
}

// ===== TEMPLATE LIST =====
function showTemplates(diseaseId){
  curDisease=diseaseId;
  var d=DISEASES.find(function(x){return x.id===diseaseId;});
  if(!d){showToast('病种数据错误');return;}
  $('tplDiseaseName').textContent=d.name;
  var html='';
  TEMPLATES.forEach(function(t){
    html+='<div class="t-item" data-tpl="'+t.id+'">'+
      '<div class="icon">'+t.icon+'</div>'+
      '<div class="info"><div class="name">'+t.name+'</div><div class="desc">'+t.desc+'</div></div>'+
      '<div class="arrow">›</div>'+
    '</div>';
  });
  $('tplList').innerHTML=html;
  showPage('pageTemplates');
}

// ===== EDITOR =====
function openEditor(diseaseId,tplId){
  curDisease=diseaseId;
  curTemplate=tplId;
  curForm={};
  var d=DISEASES.find(function(x){return x.id===diseaseId;});
  var t=TEMPLATES.find(function(x){return x.id===tplId;});
  if(!d||!t){showToast('数据错误');return;}
  $('editorTitle').textContent=d.short+' · '+t.name;
  
  // Insurance
  var ib=$('insuranceBox');
  if(d.ins&&d.ins.length){
    var ih='<div class="title">🛡️ 医保目录合规提示</div><ul>';
    d.ins.forEach(function(s){ih+='<li>'+s+'</li>';});
    ih+='</ul>';
    ib.innerHTML=ih;
  }else{
    ib.innerHTML='';
  }
  ib.classList.remove('show');
  
  // Build form
  var fields=getFields(diseaseId,tplId,d);
  var body=$('editorBody');
  var fhtml='';
  fields.forEach(function(f){
    var val=f.def||'';
    curForm[f.id]=val;
    var input='';
    if(f.type==='textarea'){
      input='<textarea id="f_'+f.id+'" class="'+(f.tall?'tall':'')+'">'+escHtml(val)+'</textarea>';
    }else if(f.type==='select'){
      input='<select id="f_'+f.id+'">';
      (f.options||[]).forEach(function(o){
        input+='<option'+(o===val?' selected':'')+'>'+escHtml(o)+'</option>';
      });
      input+='</select>';
    }else{
      input='<input type="'+f.type+'" id="f_'+f.id+'" value="'+escHtml(val)+'">';
    }
    fhtml+='<div class="form-group"><label>'+f.label+'<span style="color:#e53935;margin-left:2px;">*</span></label>'+input;
    if(f.help) fhtml+='<div class="help-text">'+f.help+'</div>';
    fhtml+='</div>';
  });
  fhtml+='<div class="btn-row">'+
    '<button class="btn btn-primary" id="genBtn">📄 生成文书</button>'+
    '<button class="btn btn-success" id="saveBtn">💾 保存</button>'+
    '<button class="btn btn-outline" id="clearBtn">清空</button>'+
  '</div>';
  body.innerHTML=fhtml;
  
  // Bind events
  // Input changes
  body.querySelectorAll('input,textarea,select').forEach(function(el){
    el.addEventListener('input',function(){curForm[this.id.replace('f_','')]=this.value;});
    el.addEventListener('change',function(){curForm[this.id.replace('f_','')]=this.value;});
  });
  $('genBtn').addEventListener('click',generateDoc);
  $('saveBtn').addEventListener('click',saveRecord);
  $('clearBtn').addEventListener('click',function(){if(confirm('确定清空当前填写内容？'))openEditor(diseaseId,tplId);});
  
  showPage('pageEditor');
}

function escHtml(s){
  if(typeof s!=='string') return '';
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ===== FORM FIELDS =====
function getFields(did,tid,d){
  var fields=[];
  var common=[
    {id:'patient_name',label:'患者姓名',type:'text',def:''},
    {id:'gender',label:'性别',type:'select',def:'男',options:['男','女']},
    {id:'age',label:'年龄',type:'number',def:''},
    {id:'doctor',label:'记录医师',type:'text',def:''}
  ];
  if(tid==='admission') fields=getAdmissionFields(d,common);
  else if(tid==='first_course') fields=getFirstFields(d,common);
  else if(tid==='daily_course') fields=getDailyFields(d,common);
  else if(tid==='attending_round') fields=getAttendingFields(d,common);
  else if(tid==='chief_round') fields=getChiefFields(d,common);
  else if(tid==='discharge') fields=getDischargeFields(d,common);
  else fields=common;
  return fields;
}

function getAdmissionFields(d,base){
  return base.concat([
    {id:'admission_date',label:'入院时间',type:'text',def:new Date().toLocaleString('zh-CN')},
    {id:'chief_complaint',label:'主诉',type:'textarea',def:'',help:'格式：症状+时间，如"右侧肢体乏力伴言语不利3天"'},
    {id:'present_illness',label:'现病史',type:'textarea',def:'',tall:true},
    {id:'past_history',label:'既往史',type:'textarea',def:'高血压病史 年\n糖尿病病史 年\n其他：',tall:true},
    {id:'temperature',label:'体温(℃)',type:'text',def:'36.5'},
    {id:'pulse',label:'脉搏(次/分)',type:'text',def:'78'},
    {id:'bp',label:'血压(mmHg)',type:'text',def:'130/80'},
    {id:'special_exam',label:'专科检查',type:'textarea',def:d.exam||'',tall:true},
    {id:'inspection',label:'望诊',type:'textarea',def:'面色：______　舌质：______　舌苔：______'},
    {id:'pulse_type',label:'脉象',type:'text',def:'弦细'},
    {id:'syndrome_analysis',label:'辨证分析',type:'textarea',def:'',tall:true},
    {id:'west_other',label:'西医其他诊断',type:'textarea',def:''},
