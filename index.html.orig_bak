// ===== GENERATE =====
function generateDoc(){
  var d=DISEASES.find(function(x){return x.id===curDisease;});
  var t=TEMPLATES.find(function(x){return x.id===curTemplate;});
  if(!d||!t){showToast('数据错误');return;}
  
  // Collect form values
  Object.keys(curForm).forEach(function(k){
    var el=document.getElementById('f_'+k);
    if(el) curForm[k]=el.value;
  });
  
  var txt=buildTemplate(curTemplate,d,curForm);
  if(!txt){showToast('生成失败');return;}
  
  var now=new Date().toLocaleString('zh-CN');
  var full='━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   '+d.short+' · '+t.name+'\n   生成：'+now+'\n━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n'+txt;
  
  var box=$('outputBox');
  if(!box){
    // Create output box
    var body=$('editorBody');
    var ob=document.createElement('div');
    ob.id='outputBox';
    ob.className='output-box show';
    body.appendChild(ob);
    // Add copy button
    var btnRow=body.querySelector('.btn-row');
    if(btnRow){
      var cb=document.createElement('button');
      cb.className='btn btn-primary';
      cb.textContent='📋 复制文书';
      cb.addEventListener('click',function(){copyText(full);});
      var row2=document.createElement('div');
      row2.className='btn-row';
      row2.appendChild(cb);
      btnRow.parentNode.insertBefore(row2,btnRow.nextSibling);
    }
    box=ob;
  }
  box.textContent=full;
  box.classList.add('show');
  box.scrollIntoView({behavior:'smooth'});
}

function buildTemplate(tid,d,f){
  function v(k){return safeStr(f[k]);}
  function sv(k){return safeStr(d[k]);}
  var now=new Date().toLocaleString('zh-CN');
  switch(tid){
    case 'admission':
      return '【入院记录】\n\n姓名：'+v('patient_name')+'　　性别：'+v('gender')+'　　年龄：'+v('age')+'岁\n'+
        '入院时间：'+v('admission_date')+'　　记录时间：'+now+'\n\n'+
        '主诉：'+v('chief_complaint')+'\n\n现病史：'+v('present_illness')+'\n\n既往史：'+v('past_history')+'\n\n'+
        '体格检查\nT: '+v('temperature')+'℃  P: '+v('pulse')+'次/分  BP: '+v('bp')+'mmHg\n'+
        '专科检查：'+v('special_exam')+'\n\n中医四诊\n望诊：'+v('inspection')+'\n脉象：'+v('pulse_type')+'\n辨证分析：'+v('syndrome_analysis')+'\n\n'+
        '中医诊断：'+sv('tcm')+'（'+sv('syndrome')+'）\n西医诊断：'+sv('west')+'（'+v('west_other')+'）\n\n诊疗计划：'+v('treatment_plan')+'\n\n经治医师：'+v('doctor');
    case 'first_course':
      return '【首次病程记录】\n\n一、病例特点\n1. 患者'+v('patient_name')+'，'+v('gender')+'，'+v('age')+'岁，因"'+v('chief_complaint_short')+'"入院。\n'+
        '2. 查体：T '+v('temperature')+'℃ P '+v('pulse')+'次/分 BP '+v('bp')+'mmHg\n   '+v('physical_findings')+'\n\n'+
        '二、拟诊讨论\n中医诊断：'+sv('tcm')+'（'+sv('syndrome')+'）\n西医诊断：'+sv('west')+'\n\n'+
        '三、鉴别诊断\n'+v('diff_diag')+'\n\n四、诊疗计划\n'+v('treatment_plan_details')+'\n\n'+
        '中医治疗：\n  治法：'+v('tcm_therapy')+'\n  方药：'+v('tcm_prescription')+'\n康复治疗计划：'+v('rehab_plan')+'\n\n经治医师：'+v('doctor');
    case 'daily_course':
      return '【日常病程记录】\n\n日期：'+v('datetime')+'　　住院第'+v('hospital_day')+'天\n\n'+
        '一、病情变化\n患者神志'+v('consciousness')+'，精神'+v('spirit')+'，饮食'+v('appetite')+'，睡眠'+v('sleep')+'，二便'+v('stool_urine')+'。\n与前一日比较：'+v('change_status')+'\n\n'+
        '二、中医四诊\n舌象：'+v('tongue')+'　脉象：'+v('pulse_type')+'\n\n三、查体\nT: '+v('temperature')+'℃ P: '+v('pulse_rate')+'次/分 BP: '+v('blood_pressure')+'mmHg\n'+v('daily_exam')+'\n\n'+
        '四、今日治疗\n中医：'+v('today_tcm')+'\n康复：'+v('rehab_today')+'\n\n五、辨证论治\n辨证：'+v('today_syndrome')+'　治法：'+v('today_therapy')+'\n方药：'+v('today_prescription')+'\n\n六、诊疗意见\n'+v('daily_plan')+'\n\n记录医师：'+v('doctor');
    case 'attending_round':
      return '【主治医师查房记录】\n\n查房时间：'+v('round_time')+'\n主治医师：'+v('attending_doctor')+'\n住院第'+v('hospital_day')+'天\n\n'+
        '病情汇报：'+v('condition_report')+'\n\n主治医师查体：'+v('attending_exam')+'\n\n主治医师分析：'+v('attending_analysis')+'\n\n'+
        '诊疗意见：\n1. '+v('opinion_1')+'\n2. '+v('opinion_2')+'\n3. '+v('opinion_3')+'\n\n记录医师：'+v('doctor');
    case 'chief_round':
      return '【主任（副主任）医师查房记录】\n\n查房时间：'+v('round_time')+'\n主任医师：'+v('chief_doctor')+'\n住院第'+v('hospital_day')+'天\n\n'+
        '经治医师汇报病情：'+v('condition_report')+'\n\n主任医师查体：'+v('chief_exam')+'\n\n主任医师分析及指示：'+v('chief_analysis')+'\n\n'+
        '1. 关于诊断：'+v('opinion_diag')+'\n2. 关于治疗：'+v('opinion_treat')+'\n3. 关于康复：'+v('opinion_rehab')+'\n\n记录医师：'+v('doctor');
    case 'discharge':
      return '【出院记录】\n\n入院日期：'+v('admission_date')+'　　出院日期：'+v('discharge_date')+'　　住院天数：'+v('stay_days')+'天\n\n'+
        '入院情况：'+v('admission_status')+'\n\n入院诊断：'+sv('tcm')+'（'+sv('syndrome')+'）　'+sv('west')+'\n\n'+
        '诊疗经过：'+v('treatment_course')+'\n\n出院诊断：'+sv('tcm')+'（'+sv('syndrome')+'）　'+sv('west')+'\n\n'+
        '出院情况：'+v('discharge_status')+'\n\n出院医嘱：\n1. 药物治疗：'+v('medication_advice')+'\n2. 康复指导：'+v('rehab_advice')+'\n3. 复诊建议：'+v('followup_advice')+'\n\n医师签名：'+v('doctor');
    default:
      return '';
  }
}

// ===== SAVE =====
function saveRecord(){
  var d=DISEASES.find(function(x){return x.id===curDisease;});
  var t=TEMPLATES.find(function(x){return x.id===curTemplate;});
  if(!d||!t){showToast('数据错误');return;}
  
  Object.keys(curForm).forEach(function(k){
    var el=document.getElementById('f_'+k);
    if(el) curForm[k]=el.value;
  });
  
  var content=buildTemplate(curTemplate,d,curForm);
  if(!content){showToast('生成失败');return;}
  
  var record={
    id:Date.now(),
    disease:d.short,
    template:t.name,
    patient:curForm.patient_name||'未填',
    data:JSON.parse(JSON.stringify(curForm)),
    content:content,
    time:new Date().toLocaleString('zh-CN')
  };
  saved.unshift(record);
  try{localStorage.setItem('zky_saved',JSON.stringify(saved));}catch(e){}
  updateSavedCount();
  showToast('✅ 已保存');
}

function updateSavedCount(){
  $('savedCount').textContent='共 '+saved.length+' 条';
}

function showSaved(){
  var list=$('savedList');
  if(saved.length===0){
    list.innerHTML='<div style="text-align:center;padding:40px 0;color:#999;">📭 暂无保存记录</div>';
  }else{
    var html='';
    saved.forEach(function(r){
      html+='<div class="saved-item anim-in">'+
        '<div class="s-title">'+r.disease+' · '+r.template+'</div>'+
        '<div class="s-meta">患者：'+r.patient+'　'+r.time+'</div>'+
        '<div class="s-actions">'+
          '<button class="btn btn-primary" onclick="window._viewRecord('+r.id+')">查看</button>'+
          '<button class="btn btn-gray" onclick="window._copyRecord('+r.id+')">复制</button>'+
          '<button class="btn btn-danger" onclick="window._delRecord('+r.id+')">删</button>'+
        '</div></div>';
    });
    list.innerHTML=html;
  }
  updateSavedCount();
  showPage('pageSaved');
}

// Global functions for saved items
window._viewRecord=function(id){
  var r=saved.find(function(x){return x.id===id;});
  if(!r) return;
  curDisease=null;curTemplate=r.template?r.template.toLowerCase().replace(/ /g,'_'):null;
  curForm=r.data||{};
  var d0=DISEASES.find(function(x){return x.short===r.disease;});
  if(d0) curDisease=d0.id;
  var t0=TEMPLATES.find(function(x){return x.name===r.template;});
  if(t0) curTemplate=t0.id;
  if(!curDisease||!curTemplate){showToast('无法加载此记录');return;}
  var d=DISEASES.find(function(x){return x.id===curDisease;});
  var t=TEMPLATES.find(function(x){return x.id===curTemplate;});
  if(!d||!t){showToast('数据错误');return;}
  $('editorTitle').textContent=d.short+' · '+t.name;
  openEditor(curDisease,curTemplate);
  // Restore values
  setTimeout(function(){
    Object.keys(r.data||{}).forEach(function(k){
      var el=document.getElementById('f_'+k);
      if(el) el.value=r.data[k];
    });
    var box=$('outputBox');
    if(r.content&&box){box.textContent=r.content;box.classList.add('show');}
  },100);
};
window._copyRecord=function(id){
  var r=saved.find(function(x){return x.id===id;});
  if(r&&r.content) copyText(r.content);
};
window._delRecord=function(id){
  if(!confirm('确定删除？')) return;
  saved=saved.filter(function(x){return x.id!==id;});
  try{localStorage.setItem('zky_saved',JSON.stringify(saved));}catch(e){}
  showSaved();
  showToast('已删除');
};

// ===== EVENT BINDING =====
function init(){
  // Splash
  setTimeout(function(){$('splash').classList.add('hide');},600);
  
  // Search
  $('searchInput').addEventListener('input',function(){renderDiseases(this.value);});
  
  // Disease Grid (event delegation)
  $('diseaseGrid').addEventListener('click',function(e){
    var card=e.target.closest('.disease-card');
    if(card) showTemplates(card.dataset.id);
  });
  
  // Template List (event delegation)
  $('tplList').addEventListener('click',function(e){
    var item=e.target.closest('.t-item');
    if(item&&curDisease) openEditor(curDisease,item.dataset.tpl);
  });
  
  // Nav
  $('backHomeBtn').addEventListener('click',function(){showPage('pageHome');});
  $('backHomeBtn2').addEventListener('click',function(){showPage('pageHome');});
  $('backTplBtn').addEventListener('click',function(){if(curDisease)showTemplates(curDisease);});
  $('insBtn').addEventListener('click',function(){$('insuranceBox').classList.toggle('show');});
  $('navHome').addEventListener('click',function(){showPage('pageHome');});
  $('navSaved').addEventListener('click',showSaved);
  
  // Initial render
  renderDiseases('');
  updateSavedCount();
}

// ===== START =====
// Use try-catch to prevent blank page
try{
  init();
}catch(e){
  console.error(e);
  var se=$('splashErr');
  if(se){
    se.style.display='block';
    se.textContent='加载出错：'+e.message+'。点此继续';
    se.style.cursor='pointer';
    se.addEventListener('click',function(){
      $('splash').classList.add('hide');
    });
  }
}
})();
</script>
</body>
</html>
